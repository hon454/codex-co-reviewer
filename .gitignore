# Based on GitHub's gitignore templates for Node, Python, macOS, and VS Code:
# https://github.com/github/gitignore

# Local environment and secrets
.env
.env.*
!.env.example
.envrc

# Node dependencies, caches, logs, and build outputs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*
.eslintcache
.stylelintcache
coverage/
*.lcov
dist/
build/
.cache/
.parcel-cache/
.vite/
*.tsbuildinfo

# Python bytecode, virtualenvs, packaging, and test caches
__pycache__/
*.py[codz]
*$py.class
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
wheels/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Local runtime data belongs in the user's config/data directories, never here.
/config.yaml
/profiles/
/state.sqlite
*.sqlite
/artifacts/
/logs/
/worktrees/
/repos/

# Superpowers workflow artifacts are local planning scratch space.
# This repository keeps its durable harness documentation under docs/.
/docs/superpowers/

# Editor and OS files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
!*.code-workspace
*.vsix
.DS_Store
.localized
__MACOSX/
.AppleDouble
.LSOverride
._*
